<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_stock_quant_tree_herbagrata" model="ir.ui.view">
        <field name="name">stock.quant.tree.herbagrata</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable" />
        <field name="arch" type="xml">
            <field name="product_id" position="attributes">
                <attribute name="context">{'display_default_code': False}</attribute>
            </field>
            <field name="product_id" position="after">
                <field name="product_description" widget="html" />
            </field>
        </field>
    </record>
</odoo>