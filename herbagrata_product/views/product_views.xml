<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_template_form_herbagrata" model="ir.ui.view">
        <field name="name">produuct.template.form.herbagrata</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="description" widget="html" />
            </field>
        </field>
    </record>

    <record id="view_product_product_stock_tree_herbagrata" model="ir.ui.view">
        <field name="name">product.product.stock.tree.herbagrata</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_product_stock_tree" />
        <field name="arch" type="xml">
            <field name="display_name" position="after">
                <field name="description" widget="html" />
            </field>
            <field name="display_name" position="replace">
                <field name="name" />
            </field>
        </field>
    </record>

    <record id="product_tree_view4purchase_herbagrata" model="ir.ui.view">
        <field name="name">product.tree.view4purchase.herbagrata</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="purchase_quick.product_tree_view4purchase" />
        <field name="arch" type="xml">
            <field name="display_name" position="after">
                <field name="description" widget="html" />
            </field>
            <field name="display_name" position="replace">
                <field name="name" />
            </field>
        </field>
    </record>

    <record id="product_tree_view4sale_herbagrata" model="ir.ui.view">
        <field name="name">product.tree.view4sale.herbagrata</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="sale_quick.product_tree_view4sale" />
        <field name="arch" type="xml">
            <field name="display_name" position="after">
                <field name="description" widget="html" />
            </field>
            <field name="display_name" position="replace">
                <field name="name" />
            </field>
        </field>
    </record>
</odoo>