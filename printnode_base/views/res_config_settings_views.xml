<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">Settings</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40" />
            <field name="inherit_id" ref="base.res_config_settings_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Direct Print PRO" string="Direct Print PRO" name="printnode_base" groups="printnode_base.printnode_security_group_manager">
                        <h2>Account</h2>
                        <!-- Review credit block -->
                        <div class="alert alert-info row o_settings_container my-1" role="alert" style="margin-left: 4.5rem; padding-left: 0rem;" invisible="disable_advertising == True">
                            <p class="mt-1"><strong class="text-danger">🎁 €30 Credit for Your Review!</strong></p>
                            <div>
                                Leave a review on the
                                <a href="https://apps.odoo.com/apps/modules/19.0/printnode_base/#ratings" target="_blank"><strong class="text-info">Odoo App Store</strong></a>
                                and get €30 as credits for your printing subscription.
                            </div>
                            <div>
                                <a href="https://ventortech.atlassian.net/servicedesk/customer/portal/1/article/522453101" target="_blank">
                                    <small class="text-info">How to leave your review? Check the FAQ</small>
                                </a>
                            </div>
                            <div class="mt-1">
                                Just <a href="https://support.ventor.tech/" target="_blank"><strong class="text-info">contact us</strong></a> after posting - it's that simple!
                            </div>
                            <p class="mb-0"><em>Promo runs until 1 June 2026</em></p>
                        </div>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <field name="printnode_account_id" invisible="1"/> <!-- Required because it is used in the invisible condition above -->
                                    <label for="dpc_api_key" class="o_form_label d-block">API Key</label>
                                    <field name="dpc_api_key" readonly="True" class="w-100" style="word-break: break-word" />

                                    <div class="alert alert-info mt-1" role="alert" >
                                        You can find API key in your profile at
                                        <a href="https://print.ventor.tech" target="_blank">
                                            print.ventor.tech
                                        </a>
                                    </div>

                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="dpc_status" class="o_form_label d-block">Status</label>
                                    <strong class="mt-3 mb-2 d-block">
                                        <field name="dpc_status" style="color: red;" invisible="dpc_status == 'OK'"/> <!-- Required because it is used in the invisible condition above -->
                                        <field name="dpc_status" style="color: green;" invisible="dpc_status != 'OK'"/> <!-- Required because it is used in the invisible condition above -->
                                    </strong>

                                    <div class="alert alert-info mt-2" role="alert">
                                        Please, report us the text above if you have issues
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label d-block text-muted mb-2">Actions</span>
                                    <button name="%(printnode_installer_action)d" string="Quick Configuration" type="action" class="oe_highlight me-4" />
                                    <button name="import_devices" string=" Import Printers &amp; Scales" type="object" class="btn btn-outline-primary" icon="fa-cloud-download" />
                                    <br />
                                    <div class="alert alert-info mt-3" role="alert">
                                        In order to import scales, they should be connected and switched on (online)
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <div class="border border-danger rounded p-3">
                                        <p class="text-danger fw-bold mb-2"><strong>Danger Zone</strong></p>

                                        <div class="ps-2 border-start border-2 border-danger">
                                            <p class="mb-2">
                                                Re-activate the account with a complete removal of all devices from Odoo and import them again
                                            </p>
                                        </div>

                                        <button name="activate_account"
                                                    string=" Re-activate Account"
                                                    type="object"
                                                    class="btn btn-outline-danger mt-1"
                                                    icon="fa-warning"/>

                                        <div class="mt-4 ps-2 border-start border-2 border-danger">
                                            <p class="mb-2">
                                                Click on this button will remove all devices from Odoo that are not connected to the Printnode account
                                            </p>
                                        </div>

                                        <button name="clear_devices_from_odoo"
                                                    string=" Clear Devices in Odoo"
                                                    type="object"
                                                    class="btn btn-outline-danger mt-1"
                                                    icon="fa-trash"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h2>Company settings</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 o_setting_box">
                                <div class="o_setting_right_pane d-flex flex-column w-100">
                                    <button name="open_current_company"
                                                string="Configure Company Printing"
                                                type="object"
                                                class="btn btn-primary align-self-start"/>
                                    <div class="text-muted mt-3 mb-2">
                                        To configure printing for any company you need, open the relevant company and go to the Direct Print Settings tab.
                                        For the current company, click Configure Company  Printing.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h2 groups="base.group_no_one">Technical Settings</h2>
                        <div class="row mt16 o_settings_container" groups="base.group_no_one">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <field name="dpc_is_scales_debug_enabled" invisible="1" /> <!-- Required because it is used in the invisible condition above -->

                                    <!-- Button to enable debug mode for scales integration -->
                                    <button name="enable_scales_debug_mode" string="Enable debug mode for scales" type="object" class="oe_highlight"  invisible="dpc_is_scales_debug_enabled == True" /><!-- Required because it is used in the invisible condition above -->
                                    <button name="disable_scales_debug_mode" string="Disable debug mode for scales" type="object" class="oe_highlight" invisible="dpc_is_scales_debug_enabled == False" /><!-- Required because it is used in the invisible condition above -->
                                    <button name="generate_debug_scales_measurement" string="Generate Debug Scales Measurement" type="object" class="btn btn-outline-primary mt-3 mb-2" invisible="dpc_is_scales_debug_enabled == False" /><!-- Required because it is used in the invisible condition above -->

                                    <div class="text-muted mt-3 mb-2">
                                        This button will enable debug mode for scales integration. In this mode, you will be able to generate debug measurements for scales integration (without real scales).
                                        There will be created new scales named "Direct Print PRO Test Scale" connected to the computer "Computer with test scales".
                                        These devices will be automatically deleted after disabling debug mode.
                                        Please note that test scales measurement will be available for 45 seconds. After that you will need to click "Generate debug scales measurement" button again.
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="disable_advertising"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="disable_advertising" string="Disable advertising"/>
                                    <div class="text-muted">
                                        Hide information about promotions and discounts.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h2>Our Ecosystem of Products</h2>
                        <div class="row mt16 o_settings_container px-0 vt-ecosystem">
                            <div class="col-12 o_setting_box px-0">
                                <div class="container-fluid text-center">
                                    <div
                                        class="row g-4 justify-content-center">
                                        <!-- ZPL -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-zpl-label-designer/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/zpl.png" alt="Odoo ZPL Label Designer" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo ZPL Label<br/>Designer
                                                </div>
                                            </a>
                                        </div>

                                        <!-- Shopify -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-shopify-connector-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/shopify.png" alt="Odoo Shopify Connector PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo Shopify<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- PrestaShop -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-prestashop-connector-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/prestashop.png" alt="Odoo PrestaShop Connector PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo PrestaShop<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- Magento 2 -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-magento-2-connector-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/magento.png" alt="Odoo Magento 2 Connector PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo Magento 2<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- WooCommerce -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-woocommerce-connector-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/woocommerce.png" alt="Odoo WooCommerce Connector PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo WooCommerce<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- QuickBooks -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-quickbooks-online-connector-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/qbo.png" alt="Odoo QuickBooks Online Connector PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo QuickBooks<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- MyParcel -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/odoo-myparcel-connector/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/myparcel.png" alt="Odoo MyParcel Connector" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Odoo MyParcel<br/>Connector PRO
                                                </div>
                                            </a>
                                        </div>

                                        <!-- Ventor PRO -->
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                            <a href="https://ecosystem.ventor.tech/product/ventor-pro/" target="_blank" class="d-flex flex-column align-items-center text-decoration-none">
                                                <img src="/printnode_base/static/src/images/ventor-pro.png" alt="Ventor PRO" class="img-fluid rounded shadow-sm" style="max-height:96px;"/>
                                                <div class="mt-2 text-muted small">
                                                    Ventor PRO
                                                </div>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </app>
                </xpath>
            </field>
        </record>

        <record id="printnode_config_action" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
            <field name="context">{'module' : 'printnode_base'}</field>
        </record>

        <menuitem id="menu_printnode_general"
                  name="Settings"
                  parent="menu_printnode_service"
                  sequence="37"
                  action="printnode_config_action"
        />

    </data>
</odoo>
