<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="printnode_test_report">
    <t t-call="web.basic_layout">
        <div class="border-dashed font-monospace fs-6">
            <h2 class="text-center">
                Odoo Direct Print PRO – Test Page
            </h2>

            <h2 class="text-center">VentorTech</h2>
            <div class="p-4 rounded-3" style="border: 1px dashed #000;">
                <p class="fw-semibold">Odoo Direct Print PRO – Test Page</p>
                <ul class="mb-0">
                    <li>Print server connection: OK</li>
                    <li>Printer configuration: OK</li>
                </ul>
            </div>
        </div>

        <div class="mt-4">
            <p>
                <strong>Powered by VentorTech</strong><br/>
                Direct, secure, and reliable printing for Odoo
            </p>

            <p><strong>Other VentorTech products you might like</strong>:</p>
            <ul>
                <li><strong>Connectors</strong> – Sync orders, inventory, and tracking between Odoo and WooCommerce, Shopify, PrestaShop, or Magento – instantly and automatically</li>
                <li><strong>Odoo QuickBooks Online Connector PRO</strong> – Sync invoices, payments, products, and partners between Odoo and QuickBooks Online (QBO) in both directions</li>
                <li><strong>ZPL Label Designer</strong> – Create custom labels in Odoo using a visual drag &amp; drop editor – no coding required</li>
                <li><strong>Ventor PRO</strong> – Odoo barcode app for your inventory</li>
            </ul>

            <p>... and even more modules (Odoo MyParcel Connector, Odoo RabbitMQ Connector, etc.) </p>
        </div>

        <div class="d-flex justify-content-center mt-5">
            <div class="row align-items-center g-0 w-auto mt-5">
                <div class="col-auto">
                    <img t-att-src="'/report/barcode/QR/https://ecosystem.ventor.tech?width=205&amp;height=205&amp;quiet=0'"
                         width="205"
                         height="205"
                         class="img-fluid"
                         alt="VentorTech Ecosystem QR Code"/>
                </div>

                <div class="col ps-4">
                    <div class="fs-4 fw-bold mb-3">
                        <p>
                            Explore the <strong>VentorTech Ecosystem</strong><br/>
                            – your hub for smart Odoo extensions.
                        </p>
                    </div>

                    <div class="mb-3">
                        <p>
                            Scan the QR code or visit <strong>ecosystem.ventor.tech</strong>.
                        </p>
                    </div>

                    <div class="lh-1">
                        <p class="mb-0">
                            Enjoy 20% OFF with special code <strong>DP20OFF</strong>
                        </p>
                        <p class="text-muted small fst-italic mb-0 mt-0">
                            (valid for your first purchase)
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </t>
</template>

    <record id="action_report_printnode_test" model="ir.actions.report">
        <field name="name">Test Print Report</field>
        <field name="model">printnode.printer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">printnode_base.printnode_test_report</field>
        <field name="report_file">printnode_base.printnode_test_report</field>
        <field name="print_report_name">'Test Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_printnode_printer"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
