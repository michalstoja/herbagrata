<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//tbody[hasclass('invoice_tbody')]/t[@t-foreach]" position="before">
            <t t-if="o.move_type == 'out_invoice'">
                <tr name="plant_passport_row">
                    <td name="td_plant_passport" style="border-top: 1px solid black; border-left: 1px solid black; border-right: 1px solid black; padding: 4px 6px; vertical-align: top;">
                        <table style="border-collapse: collapse; width: 100%; font-size: 9pt;">
                            <tr>
                                <td colspan="2" style="padding-bottom: 2px;">
                                    <img src="/herbagrata_account/static/src/img/eu_flag.svg" style="height: 16px; width: 25px; vertical-align: middle; margin-right: 4px;"/>
                                    <strong style="font-size: 9pt;">Plant Passport / Rostlinolékařský pas</strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding-right: 12px; white-space: nowrap;">
                                    <strong>B: </strong>CZ - 0656</td>
                                <td style="white-space: nowrap;">
                                    <strong>C: </strong>10010 KontRad</td>
                            </tr>
                            <tr>
                                <td style="padding-right: 12px; white-space: nowrap;">
                                    <strong>A: </strong>
                                </td>
                                <td style="white-space: nowrap;">
                                    <strong>D: </strong>CZ</td>
                            </tr>
                        </table>
                    </td>
                    <td colspan="99"></td>
                </tr>
            </t>
        </xpath>
        <xpath expr="//td[@name='account_invoice_line_name']" position="attributes">
            <attribute name="t-attf-style">#{o.move_type == 'out_invoice' and 'border-left: 1px solid black; border-right: 1px solid black;' or ''} #{o.move_type == 'out_invoice' and line_last and 'border-bottom: 1px solid black;' or ''}</attribute>
        </xpath>
    </template>
</odoo>
